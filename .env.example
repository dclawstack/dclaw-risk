# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dclaw_risk
APP_ENV=dev
DEBUG=true
CORS_ORIGINS=["http://localhost:3092"]

# AI - LLM provider abstraction (Ollama default, OpenRouter fallback)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_REQUEST_TIMEOUT_S=60

# DClaw Compliance integration (P1.4) — leave URL empty for mock-mode fixture
COMPLIANCE_BASE_URL=
COMPLIANCE_MOCK_MODE=true

# Auth (Logto)
LOGTO_ISSUER=
LOGTO_JWKS_URI=
LOGTO_AUDIENCE=
DEV_AUTH_BYPASS=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:18162
